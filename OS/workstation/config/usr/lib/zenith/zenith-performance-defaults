#!/bin/sh
set +e

profile_id=generic-workstation
profile_name="Generic x86_64 Workstation"
profile_power_policy=balanced

if [ -r /run/zenith/hardware-profile.env ]; then
    . /run/zenith/hardware-profile.env
    profile_id="${ZENITH_PROFILE_ID:-$profile_id}"
    profile_name="${ZENITH_PROFILE_NAME:-$profile_name}"
    profile_power_policy="${ZENITH_PROFILE_POWER_POLICY:-$profile_power_policy}"
fi

has_ac_power() {
    for online in /sys/class/power_supply/A*/online /sys/class/power_supply/AC*/online; do
        if [ -r "$online" ] && [ "$(cat "$online")" = "1" ]; then
            return 0
        fi
    done
    return 1
}

set_power_profile() {
    command -v powerprofilesctl >/dev/null 2>&1 || return 0

    wanted=balanced
    case "$profile_power_policy" in
        performance)
            wanted=performance
            ;;
        ac-performance-battery-balanced)
            if has_ac_power; then
                wanted=performance
            fi
            ;;
        balanced|*)
            wanted=balanced
            ;;
    esac

    if [ "$wanted" = "performance" ] && powerprofilesctl list 2>/dev/null | grep -q "performance:"; then
        powerprofilesctl set performance >/dev/null 2>&1 && {
            printf '%s\n' "zenith-performance-defaults: $profile_id ($profile_name) -> performance"
            return 0
        }
    fi

    powerprofilesctl set balanced >/dev/null 2>&1 || true
    printf '%s\n' "zenith-performance-defaults: $profile_id ($profile_name) -> balanced"
}

set_power_profile
exit 0
