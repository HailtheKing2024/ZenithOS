#!/bin/bash
# ZenithOS Performance Defaults - Lenovo V14-ADA Optimized
# Runs on first boot to optimize system performance

set -e

echo "🚀 ZenithOS Performance Optimizer"
echo "=================================="
echo "Target: Lenovo V14-ADA (AMD Athlon/Ryzen Mobile, 4-8GB RAM)"
echo ""

# 1. Set CPU Governor to performance when on AC power
echo "⚡ Configuring CPU frequency governor..."
if command -v cpupower >/dev/null 2>&1; then
    # Set to performance mode when plugged in
    cpupower frequency-set -g performance 2>/dev/null || true
    echo "✅ CPU governor set to performance"
else
    echo "⚠️  cpupower not available, using defaults"
fi

# 2. Optimize VM swappiness for better responsiveness
echo "💾 Optimizing memory management..."
current_swappiness=$(cat /proc/sys/vm/swappiness 2>/dev/null || echo "60")
echo "10" > /proc/sys/vm/swappiness 2>/dev/null || true
if [ -f /etc/sysctl.conf ]; then
    if ! grep -q "vm.swappiness=10" /etc/sysctl.conf; then
        echo "vm.swappiness=10" >> /etc/sysctl.conf
    fi
fi
echo "✅ Swappiness reduced from $current_swappiness to 10 (better responsiveness)"

# 3. Enable zram for compressed swap (great for 4-8GB systems)
echo "🔄 Configuring zram compressed swap..."
if command -v zramctl >/dev/null 2>&1; then
    # Create zram device if not already enabled
    if ! grep -q zram /proc/swaps; then
        modprobe zram 2>/dev/null || true
        zramctl --algo zstd --size $(($(grep MemTotal /proc/meminfo | awk '{print $2}') / 2))M /dev/zram0 2>/dev/null || true
        mkswap /dev/zram0 2>/dev/null || true
        swapon /dev/zram0 2>/dev/null || true
        echo "✅ Zram enabled (50% of RAM as compressed swap)"
    else
        echo "✅ Zram already enabled"
    fi
else
    echo "⚠️  zramctl not available, skipping"
fi

# 4. Optimize I/O scheduler for SSD (if detected)
echo "💿 Optimizing I/O scheduler..."
for disk in /sys/block/sd*/queue/scheduler /sys/block/nvme*/queue/scheduler; do
    if [ -e "$disk" ]; then
        # Prefer 'mq-deadline' or 'none' for SSDs
        current_scheduler=$(cat "$disk" 2>/dev/null | grep -o '\[.*\]' || echo "[unknown]")
        if echo "$current_scheduler" | grep -q "mq-deadline"; then
            echo "mq-deadline" > "$disk" 2>/dev/null || true
            echo "✅ I/O scheduler set to mq-deadline for $(basename $(dirname $disk))"
        elif echo "$current_scheduler" | grep -q "none"; then
            echo "none" > "$disk" 2>/dev/null || true
            echo "✅ I/O scheduler set to none for $(basename $(dirname $disk))"
        fi
    fi
done

# 5. Disable unnecessary services for faster boot
echo "🛑 Disabling non-essential services..."
for service in \
    bluetooth.service \
    cups.service \
    ModemManager.service; do
    if systemctl list-unit-files | grep -q "$service"; then
        systemctl disable "$service" 2>/dev/null || true
        echo "✅ Disabled $service (can be enabled if needed)"
    fi
done

# 6. Configure power management for AMD GPU
echo "🎨 Configuring AMD GPU power management..."
if [ -d /sys/class/drm/card0 ]; then
    # Enable automated GPU power management
    if [ -e /sys/class/drm/card0/device/power_profile ]; then
        echo "auto" > /sys/class/drm/card0/device/power_profile 2>/dev/null || true
        echo "✅ AMD GPU power profile set to auto"
    fi
    if [ -e /sys/class/drm/card0/device/power_dpm_force_performance_level ]; then
        echo "auto" > /sys/class/drm/card0/device/power_dpm_force_performance_level 2>/dev/null || true
        echo "✅ AMD DPM force performance level set to auto"
    fi
fi

# 7. Optimize NetworkManager for faster connections
echo "🌐 Optimizing network configuration..."
if [ -f /etc/NetworkManager/NetworkManager.conf ]; then
    # Add WiFi power saving disable for better performance
    cat >> /etc/NetworkManager/conf.d/zenith-performance.conf <<EOF
[connection]
wifi.powersave = 2
EOF
    echo "✅ WiFi power saving disabled for better performance"
fi

# 8. Set kernel parameters for better desktop responsiveness
echo "⚙️  Applying kernel parameter optimizations..."
cat >> /etc/sysctl.d/99-zenith-performance.conf <<EOF
# ZenithOS Performance Optimizations
# Reduce latency for interactive applications
kernel.perf_event_paranoid=2
kernel.pid_max=4194

# Improve network performance
net.core.rmem_max=16777216
net.core.wmem_max=16777216
net.ipv4.tcp_rmem=4096 87380 16777216
net.ipv4.tcp_wmem=4096 65536 16777216

# Reduce swap tendency (runtime override)
vm.swappiness=10

# Improve filesystem performance
vm.dirty_ratio=40
vm.dirty_background_ratio=10
vm.vfs_cache_pressure=50
EOF
echo "✅ Kernel parameters optimized"

# 9. Enable TRIM for SSDs (if supported)
echo "🗑️  Checking TRIM support..."
if command -v fstrim >/dev/null 2>&1; then
    # Enable periodic TRIM
    systemctl enable fstrim.timer 2>/dev/null || true
    echo "✅ Automatic TRIM enabled for SSD maintenance"
fi

# 10. Configure thermal management
echo "🌡️  Configuring thermal management..."
if [ -d /sys/class/thermal ]; then
    # Set thermal zone to balanced mode if available
    for zone in /sys/class/thermal/thermal_zone*/mode; do
        if [ -e "$zone" ]; then
            current_mode=$(cat "$zone" 2>/dev/null || echo "unknown")
            if [ "$current_mode" = "performance" ] || [ "$current_mode" = "balanced" ]; then
                # Already optimized
                echo "✅ Thermal zone $(basename $(dirname $zone)): $current_mode"
            fi
        fi
    done
fi

echo ""
echo "=================================="
echo "✨ Performance optimization complete!"
echo ""
echo "Summary of optimizations:"
echo "  • CPU governor: performance mode"
echo "  • Memory swappiness: reduced to 10"
echo "  • Zram: enabled (compressed swap)"
echo "  • I/O scheduler: optimized for SSD"
echo "  • Non-essential services: disabled"
echo "  • AMD GPU: auto power management"
echo "  • WiFi: power saving disabled"
echo "  • Network: performance tuned"
echo "  • TRIM: automatic enabled"
echo ""
echo "Your Lenovo V14-ADA is now optimized for:"
echo "  ⚡ Faster application launch"
echo "  🎯 Lower input latency"
echo "  💾 Better memory management"
echo "  🔋 Balanced power/performance"
echo ""
echo "Note: Some changes require reboot to take full effect."

# Mark optimization as complete
touch /var/lib/zenith/performance-optimized.flag
echo "🎉 ZenithOS ready for peak performance!"