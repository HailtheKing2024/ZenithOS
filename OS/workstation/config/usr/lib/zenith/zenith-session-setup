#!/bin/sh
set -u

if command -v gsettings >/dev/null 2>&1; then
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' || true
    gsettings set org.gnome.desktop.interface clock-show-weekday true || true
    gsettings set org.gnome.desktop.interface cursor-theme 'Adwaita' || true
    gsettings set org.gnome.desktop.interface cursor-size 48 || true
    gsettings set org.gnome.desktop.interface enable-animations false || true
    gsettings set org.gnome.desktop.background picture-uri 'file:///usr/share/backgrounds/zenith/zenith-default.svg' || true
    gsettings set org.gnome.desktop.background picture-uri-dark 'file:///usr/share/backgrounds/zenith/zenith-default.svg' || true
    gsettings set org.gnome.desktop.background picture-options 'zoom' || true
    gsettings set org.gnome.desktop.screensaver picture-uri 'file:///usr/share/backgrounds/zenith/zenith-default.svg' || true
    gsettings set org.gnome.desktop.peripherals.touchpad tap-to-click true || true
    gsettings set org.gnome.desktop.peripherals.touchpad natural-scroll true || true
    gsettings set org.gnome.mutter dynamic-workspaces true || true
    gsettings set org.gnome.mutter edge-tiling true || true
    gsettings set org.gnome.shell disable-user-extensions false || true
    gsettings set org.gnome.shell enabled-extensions "['zenith-shell@zenithos.local']" || true
    gsettings set org.gnome.shell favorite-apps "['os.zenith.Welcome.desktop', 'os.zenith.Terminal.desktop', 'os.zenith.Settings.desktop', 'os.zenith.Files.desktop', 'os.zenith.Packages.desktop', 'os.zenith.Installer.desktop', 'zenith-build.desktop']" || true
fi

if command -v gnome-extensions >/dev/null 2>&1; then
    gnome-extensions enable zenith-shell@zenithos.local || true
fi

exit 0
