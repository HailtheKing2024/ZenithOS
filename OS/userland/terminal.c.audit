CONSTRAINT_MATRIX = [
  {constraint_id: C1, status: PASS, evidence: "build/userland/terminal.bin = 3713 bytes <= 32768"},
  {constraint_id: C2, status: PASS, evidence: "userland/terminal.c includes zenith/user.h and stdbool.h only; user.h includes stdint.h"},
  {constraint_id: C3, status: PASS, evidence: "z_spawn(path,arg) wrapper maps to syscall 12 with single arg pointer; terminal does not spawn"},
  {constraint_id: C4, status: FAIL, evidence: "Z_UI_TEXT_CAP/UI_TEXT_CAP = 64 exists; PKG_INFO/PKG_SEARCH paged protocol is absent"},
  {constraint_id: C5, status: PASS, evidence: "terminal performs no filesystem mutation; current open/read/write layer only exposes pseudo-device FDs"},
  {constraint_id: C6, status: PASS, evidence: "audited terminal code is project-local simple control logic; no copied external implementation detected"},
  {constraint_id: C7, status: PASS, evidence: "ZENITH_SYSCALL_COUNT = 28; no syscall numbers after 27 exist in current ABI"},
  {constraint_id: C8, status: PASS, evidence: "terminal communicates through z_ui_send/z_ui_recv; no kernel subsystem is embedded into user terminal"},
  {constraint_id: C9, status: FAIL, evidence: "terminal registers 760x472 UI window; no 1280x800 framebuffer contract is asserted in terminal source"},
  {constraint_id: C10, status: PASS, evidence: "current process ABI uses per-process user image and syscall-mediated access; no shared memory path in terminal"},
  {constraint_id: C11, status: FAIL, evidence: "Z_UI_CMD_BRIDGE_DATA is not implemented; current bridge-only commands use Z_UI_MSG_COMMAND with legacy command IDs"},
  {constraint_id: C12, status: PASS, evidence: "bridge-only commands SETTINGS and OVERVIEW call z_ui_send only; terminal has zero z_open/z_read/z_close call sites"}
]

