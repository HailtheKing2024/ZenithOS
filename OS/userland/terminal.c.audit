Z_UI_CMD_BRIDGE_DATA_DEFINITION = {
  status: "reserved by audit; not implemented in headers",
  proposed_command_value: 5,
  carrier_type: "Z_UI_MSG_COMMAND",
  a: "Z_UI_CMD_BRIDGE_DATA",
  b: "bridge stream id or page cursor",
  c: "flags: bit0=request, bit1=response, bit2=truncated, bit3=paged",
  text_layout: {
    byte_0: "opcode: 0=data, 1=command, 2=pkg_first_page, 3=pkg_next_page, 4=error",
    byte_1: "line_count for paged PKG response, otherwise 0",
    byte_2: "page_index",
    byte_3: "payload_len, max 56",
    bytes_4_to_7: "reserved, zero",
    bytes_8_to_63: "payload, max 56 bytes"
  },
  pkg_first_response: "text[1] carries total line_count; text[8..63] carries first line",
  pkg_page_advance: "KEY_DOWN from terminal requests next page using same stream id",
  invariant: "payload_len <= 56; total IPC text cap remains 64"
}

